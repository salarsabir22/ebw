# Copy to `.env.local` — never commit real keys.

# Resend (https://resend.com/api-keys) — only this is required for the contact form.
RESEND_API_KEY=

# After you verify your domain in Resend, set a branded “from” (otherwise the app uses onboarding@resend.dev).
# INQUIRY_FROM_EMAIL=Expression Beyond Words <hello@yourdomain.com>

# --- Optional: SMTP (preferred — bypasses Resend if all three are set) ---
# Works with any SMTP provider: AWS SES (HIPAA-eligible w/ AWS BAA), Zoho, Gmail App Password, etc.
#
# AWS SES SMTP example (region in the host, e.g. us-east-1 / us-east-2 / eu-west-1):
#   SMTP_HOST=email-smtp.us-east-1.amazonaws.com
#   SMTP_PORT=587
#   SMTP_SECURE=false        # 587 + STARTTLS; set true for 465
#   SMTP_USER=<SES SMTP username from "Create SMTP credentials">
#   SMTP_PASSWORD=<SES SMTP password>
#   INQUIRY_FROM_EMAIL=Expression Beyond Words PLLC <info@expressionbeyondwords.com>
#                            # MUST match a verified SES identity (domain or email).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
