# Copy to `.env.local` for local dev, and set these in your host (Vercel, etc.) for production.

# --- Recommended: Resend (no SMTP server needed) ---
# 1) Create a free account at https://resend.com
# 2) Add & verify your domain, then create an API key
# 3) Use a “from” address on that verified domain
RESEND_API_KEY=
INQUIRY_FROM_EMAIL=Expression Beyond Words <noreply@yourdomain.com>

# Optional — inbox where inquiries arrive (defaults to info@expressionbeyondwords.com in site config)
# INQUIRY_TO_EMAIL=

# --- Optional: SMTP (only if your email host gives you SMTP credentials) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_SECURE=false
# INQUIRY_FROM_EMAIL=
